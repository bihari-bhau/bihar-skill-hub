# ── Bihar Skill Hub — Environment Variables ───────────────────────────────────
# Copy this file to backend/.env and fill in your values.

# Django
SECRET_KEY=django-insecure-replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — your React dev URL
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (console output in dev, configure SMTP for production)
DEFAULT_FROM_EMAIL=noreply@biharskillhub.com

# PostgreSQL (optional — only needed if switching from SQLite)
# DB_NAME=bihar_skill_hub
# DB_USER=bsh_user
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432
